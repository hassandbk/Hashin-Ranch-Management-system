<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="addBreedVBox" alignment="CENTER" maxWidth="-Infinity" prefHeight="403.0" prefWidth="476.0" spacing="10" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1">

    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Add New Breed" />

    <HBox alignment="CENTER" spacing="5">
        <Label text="ID:" />
        <TextField fx:id="breedIdTextField" maxWidth="-Infinity" minWidth="-Infinity" promptText="Enter Breed ID" />
        <Label text="Breed Name:" />
        <TextField fx:id="breedNameTextField" maxWidth="-Infinity" minWidth="-Infinity" promptText="Enter Breed name" />
    </HBox>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Origin:" />
        <TextField fx:id="originTextField" maxWidth="-Infinity" minWidth="-Infinity" promptText="Enter Origin" />
        <Label text="Recognition:" />
        <CheckBox fx:id="recognitionCheckBox" />
    </HBox>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Comments:" />
        <TextArea fx:id="commentsTextArea" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="192.0" prefWidth="390.0" promptText="Enter Comments" />
    </HBox>

    <Button text="Add Breed" />

</VBox>
