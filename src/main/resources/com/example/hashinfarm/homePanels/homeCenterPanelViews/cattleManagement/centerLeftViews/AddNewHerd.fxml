<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="addHerdVBox" alignment="CENTER" maxWidth="-Infinity" prefHeight="403.0" prefWidth="476.0" spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Add New Herd" />

    <HBox alignment="CENTER" spacing="5">
        <Label text="Herd Name:" />
        <TextField fx:id="herdNameTextField" maxWidth="-Infinity" minWidth="-Infinity" promptText="Enter Herd name" />
        <Label text="Total Animals:" />
        <TextField fx:id="totalAnimalsTextField" maxWidth="-Infinity" minWidth="-Infinity" promptText="Enter total no. of cattle" />
    </HBox>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Animal Class:" />
        <ComboBox fx:id="animalClassComboBox" maxWidth="-Infinity" minWidth="-Infinity" promptText="Select Animal Class">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Growing" />
                    <String fx:value="Lactating Cows" />
                    <String fx:value="Dry Cows" />
                    <String fx:value="Replacement Heifers" />
                </FXCollections>
            </items>
        </ComboBox>
        <Label text="Breed Type:" />
        <ComboBox fx:id="breedTypeComboBox" maxWidth="-Infinity" minWidth="-Infinity" promptText="Select Breed Type">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Breed 1" />
                    <String fx:value="Breed 2" />
                    <String fx:value="Breed 3" />
                </FXCollections>
            </items>
        </ComboBox>
    </HBox>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Solution Type:" />
        <ComboBox fx:id="solutionTypeComboBox" maxWidth="-Infinity" minWidth="-Infinity" promptText="Select Solution Type">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Eqivalent Livestock System (ELS)" />
                    <String fx:value="Multiple Livestock System (MLS)" />
                   </FXCollections>
            </items>

        </ComboBox>
    </HBox>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Feed Basis:">
       </Label>
        <ComboBox fx:id="feedBasisComboBox" promptText="Select Feed Basis">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Dry Matter (DM)" />
                    <String fx:value="AS-Fed (AF)" />

                </FXCollections>
            </items>

        </ComboBox>
    </HBox>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Location:" />
        <TextField fx:id="locationTextField" promptText="Eneter Herd Location" />
    </HBox>

    <Button text="Add Herd" />

</VBox>
